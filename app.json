{
    "expo": {
    "name": "kalendars",
    "slug": "kalendars",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kalendars",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#efefef",
    "androidNavigationBar": {
      "backgroundColor": "#efefef",
      "barStyle": "dark-content"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "Aplikācija izmanto kontaktus, lai palīdzētu tev atcerēties draugu vārda dienas."
      }
    },
    "android": {
      "permissions": [
        "READ_CONTACTS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "backgroundColor": "#efefef",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "statusBar": {
        "barStyle": "dark-content",
        "translucent": true
      },
      "navigationBar": {
        "backgroundColor": "#efefef",
        "barStyle": "dark-content"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anngaa.kalendars"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-system-ui"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "212419da-b44f-4a6a-9d4e-76132bc64594"
      }
    }
  }
}
